{
  "name": "cyanprint",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "bin": {
    "cyanprint": "packages/cli/src/main.ts"
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "cache:e2e": "bun run e2e/full-stack/cache-e2e.ts",
    "ci:local": "bun run typecheck && bun run test && bun run build && bun run lint && bun run seed:check && bun run e2e && bun run e2e:cache && bun run e2e:trust && bun run e2e:wrangler && bun run web:e2e && bun run docs:check && bun run fr:check && bun run package:check && bun run release:check",
    "cyan": "bun run packages/cli/src/main.ts",
    "cyanprint": "bun run packages/cli/src/main.ts",
    "docs:check": "bun run scripts/ci/docs-check.ts",
    "deploy:cloudflare:bootstrap": "bun run scripts/cloudflare/ensure-release-resources.ts",
    "deploy:release": "bash scripts/cloudflare/deploy-release.sh",
    "deploy:worker": "bun run --filter @cyanprint/worker deploy",
    "deploy:web": "bun run --filter @cyanprint/web deploy",
    "e2e": "bun run e2e:matrix && bun run e2e:full && bun run e2e:push",
    "e2e:cache": "bun run e2e/full-stack/cache-e2e.ts",
    "e2e:create": "bun run cyan -- create examples/templates/hello --out .tmp/e2e/create --headless --answers examples/templates/hello/answers.json --json",
    "e2e:full": "bun test e2e/full-stack/run-full-e2e.test.ts",
    "e2e:matrix": "bun test e2e/e2e-matrix.test.ts",
    "e2e:push": "bun test e2e/full-stack/push-e2e.test.ts",
    "e2e:push:script": "bun run e2e/full-stack/push-e2e.ts",
    "e2e:trust": "bun run e2e/full-stack/trust-e2e.ts",
    "e2e:try-test:timed": "bun run e2e/full-stack/timed-e2e.ts try-test",
    "e2e:update:timed": "bun run e2e/full-stack/timed-e2e.ts update",
    "e2e:update:user-edits": "bun run e2e/full-stack/update-user-edits.ts",
    "e2e:wrangler": "bun run e2e/full-stack/wrangler-registry-e2e.ts",
    "fr:check": "bun run scripts/ci/fr-check.ts",
    "knip": "bun run scripts/ci/knip-precommit.ts",
    "lint": "pre-commit run --all-files",
    "package:check": "bun run scripts/ci/package-check.ts",
    "perf:local": "bun run e2e/full-stack/timed-e2e.ts all",
    "registry:test": "bun test apps/worker",
    "release:check": "bun run scripts/ci/release-check.ts",
    "seed:check": "bun run scripts/ci/seed-registry-check.ts",
    "seed:update": "bun run scripts/ci/seed-registry-update.ts",
    "integration": "bun test apps/worker packages/artifact-bundler packages/artifact-runner packages/cli packages/core",
    "test": "bun run unit && bun run integration",
    "test:all": "bun run test && bun run e2e",
    "sdk:types:emit": "bun run scripts/ci/emit-sdk-types.ts",
    "unit": "bun test apps/web packages/contracts packages/registry-client",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web:dev": "bun run --filter @cyanprint/web dev",
    "web:e2e": "bun run e2e/web/run-web-e2e.ts",
    "worker:dev": "bun run --filter @cyanprint/worker dev",
    "worker:test": "bun test apps/worker"
  },
  "dependencies": {
    "@atomicloud/cyan-sdk": "workspace:*",
    "eta": "^3.1.1",
    "next": "15.5.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "smob": "1.6.0",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bun": "1.3.4",
    "@types/node": "25.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@opennextjs/cloudflare": "1.20.1",
    "bun-types": "1.3.4",
    "knip": "6.22.0",
    "typescript": "5.9.3",
    "wrangler": "4.55.0"
  }
}
