{
  "name": "@cyanprint/worker",
  "version": "4.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p ../../tsconfig.json --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply cyanprint-local --local",
    "db:migrate:release": "wrangler d1 migrations apply DB --env release --remote",
    "db:tables:local": "wrangler d1 execute cyanprint-local --local --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\"",
    "deploy": "wrangler deploy",
    "deploy:release": "wrangler deploy --env release",
    "dev": "wrangler dev",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cyanprint/contracts": "workspace:*",
    "@cyanprint/registry-client": "workspace:*",
    "fzstd": "0.1.1",
    "hono": "4.10.7",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "wrangler": "4.55.0"
  }
}
